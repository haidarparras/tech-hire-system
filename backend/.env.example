# ── Backend Node.js (.env) ──────────────────────────────────────
# Salin file ini menjadi .env dan isi nilainya

# Supabase PostgreSQL Connection
# Dapatkan dari: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

PORT=5000

# WAJIB: Ganti dengan string acak yang kuat di production!
# Generate contoh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_SECRET_KEY_YANG_KUAT_DAN_PANJANG
